        "# =========================\n",
        "# 📊 AUTOMATIC PERFORMANCE ANALYSIS\n",
        "# =========================\n",
        "\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# -------------------------\n",
        "# STEP 1: READ TIMES\n",
        "# -------------------------\n",
        "def read_time(file):\n",
        "    try:\n",
        "        with open(file, \"r\") as f:\n",
        "            return float(f.read().strip())\n",
        "    except:\n",
        "        print(f\"⚠ Error reading {file}\")\n",
        "        return None\n",
        "\n",
        "serial = read_time(\"serial_time.txt\")\n",
        "openmp = read_time(\"openmp_time.txt\")\n",
        "mpi = read_time(\"mpi_time.txt\")\n",
        "hybrid = read_time(\"hybrid_time.txt\")\n",
        "\n",
        "# Remove None values safely\n",
        "methods = []\n",
        "times = []\n",
        "\n",
        "if serial: methods.append(\"Serial\"); times.append(serial)\n",
        "if openmp: methods.append(\"OpenMP\"); times.append(openmp)\n",
        "if mpi: methods.append(\"MPI\"); times.append(mpi)\n",
        "if hybrid: methods.append(\"Hybrid\"); times.append(hybrid)\n",
        "\n",
        "print(\"\\n⏱ Execution Times:\")\n",
        "for m, t in zip(methods, times):\n",
        "    print(f\"{m}: {t:.6f}\")\n",
        "\n",
        "# -------------------------\n",
        "# STEP 2: TIME GRAPH\n",
        "# -------------------------\n",
        "plt.figure()\n",
        "plt.bar(methods, times)\n",
        "plt.xlabel(\"Method\")\n",
        "plt.ylabel(\"Execution Time (seconds)\")\n",
        "plt.title(\"Execution Time Comparison\")\n",
        "plt.grid(axis='y')\n",
        "plt.show()\n",
        "\n",
        "# -------------------------\n",
        "# STEP 3: SPEEDUP\n",
        "# -------------------------\n",
        "def safe_div(a, b):\n",
        "    return a / b if b and b > 0 else 0\n",
        "\n",
        "speedup = []\n",
        "labels = []\n",
        "\n",
        "for m, t in zip(methods, times):\n",
        "    if m != \"Serial\":\n",
        "        labels.append(m)\n",
        "        speedup.append(safe_div(serial, t))\n",
        "\n",
        "print(\"\\n⚡ Speedup:\")\n",
        "for l, s in zip(labels, speedup):\n",
        "    print(f\"{l}: {s:.3f}\")\n",
        "\n",
        "plt.figure()\n",
        "plt.bar(labels, speedup)\n",
        "plt.xlabel(\"Method\")\n",
        "plt.ylabel(\"Speedup (T_serial / T_parallel)\")\n",
        "plt.title(\"Speedup Comparison\")\n",
        "plt.grid(axis='y')\n",
        "plt.show()\n",
        "\n",
        "# -------------------------\n",
        "# STEP 4: EFFICIENCY\n",
        "# -------------------------\n",
        "# ⚠️ Adjust based on your run\n",
        "OMP_THREADS = 2\n",
        "MPI_PROCS = 1   # since you used np=1\n",
        "\n",
        "proc_map = {\n",
        "    \"OpenMP\": OMP_THREADS,\n",
        "    \"MPI\": MPI_PROCS,\n",
        "    \"Hybrid\": OMP_THREADS * MPI_PROCS\n",
        "}\n",
        "\n",
        "efficiency = []\n",
        "\n",
        "print(\"\\n⚙ Efficiency:\")\n",
        "for l, s in zip(labels, speedup):\n",
        "    p = proc_map.get(l, 1)\n",
