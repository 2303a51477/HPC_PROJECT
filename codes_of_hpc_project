      "cell_type": "code",
      "source": [
        "%%writefile mpi.c\n",
        "#include <mpi.h>\n",
        "#include <stdio.h>\n",
        "#include <stdlib.h>\n",
        "#include <limits.h>\n",
        "\n",
        "#define MAX 2000\n",
        "#define REPEAT 20\n",
        "\n",
        "int graph[MAX][MAX];\n",
        "int dist[MAX];\n",
        "int visited[MAX];\n",
        "int n;\n",
        "\n",
        "int main(int argc, char *argv[]) {\n",
        "\n",
        "    int rank, size;\n",
        "    MPI_Init(&argc, &argv);\n",
        "    MPI_Comm_rank(MPI_COMM_WORLD, &rank);\n",
        "    MPI_Comm_size(MPI_COMM_WORLD, &size);\n",
        "\n",
        "    if (rank == 0) {\n",
        "        FILE *f = fopen(\"graph.txt\", \"r\");\n",
        "        if (!f) { printf(\"File error\\n\"); MPI_Abort(MPI_COMM_WORLD,1); }\n",
        "\n",
        "        fscanf(f, \"%d\", &n);\n",
        "\n",
        "        for (int i = 0; i < n; i++)\n",
        "            for (int j = 0; j < n; j++)\n",
        "                fscanf(f, \"%d\", &graph[i][j]);\n",
        "\n",
        "        fclose(f);\n",
        "    }\n",
        "\n",
        "    MPI_Bcast(&n, 1, MPI_INT, 0, MPI_COMM_WORLD);\n",
        "    MPI_Bcast(graph, n*n, MPI_INT, 0, MPI_COMM_WORLD);\n",
        "\n",
        "    double start = MPI_Wtime();\n",
        "\n",
        "    for (int r = 0; r < REPEAT; r++) {\n",
        "\n",
        "        for (int i = 0; i < n; i++) {\n",
        "            dist[i] = INT_MAX;\n",
        "            visited[i] = 0;\n",
        "        }\n",
        "\n",
        "        dist[0] = 0;\n",
        "\n",
        "        for (int count = 0; count < n - 1; count++) {\n",
        "\n",
        "            int local_min = INT_MAX, local_idx = -1;\n",
        "\n",
        "            for (int i = rank; i < n; i += size) {\n",
        "                if (!visited[i] && dist[i] < local_min) {\n",
        "                    local_min = dist[i];\n",
        "                    local_idx = i;\n",
        "                }\n",
        "            }\n",
        "\n",
        "            struct { int val, idx; } local = {local_min, local_idx}, global;\n",
        "\n",
        "            MPI_Allreduce(&local, &global, 1, MPI_2INT, MPI_MINLOC, MPI_COMM_WORLD);\n",
        "\n",
        "            int u = global.idx;\n",
        "            if (u == -1) break;\n",
        "\n",
        "            visited[u] = 1;\n",
        "\n",
        "            for (int v = rank; v < n; v += size) {\n",
        "                if (!visited[v] && graph[u][v] &&\n",
        "                    dist[u] != INT_MAX) {\n",
        "\n",
        "                    int new_dist = dist[u] + graph[u][v];\n",
        "                    if (new_dist < dist[v])\n",
        "                        dist[v] = new_dist;\n",
        "                }\n",
        "            }\n",
        "\n",
        "            MPI_Allreduce(MPI_IN_PLACE, dist, n, MPI_INT, MPI_MIN, MPI_COMM_WORLD);\n",
        "        }\n",
        "    }\n",
        "\n",
        "    double end = MPI_Wtime();\n",
        "\n",
        "    if (rank == 0) {\n",
        "        FILE *out = fopen(\"mpi_time.txt\", \"w\");\n",
        "        fprintf(out, \"%f\", end - start);\n",
        "        fclose(out);\n",
        "\n",
        "        printf(\"MPI Time: %f\\n\", end - start);\n",
        "    }\n",
        "\n",
        "    MPI_Finalize();\n",
        "    return 0;\n",
        "}"
