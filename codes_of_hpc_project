      "source": [
        "import random\n",
        "\n",
        "N = 500\n",
        "\n",
        "def generate_graph(n=N):\n",
        "    graph = [[0]*n for _ in range(n)]\n",
        "    for i in range(n):\n",
        "        for j in range(n):\n",
        "            if i != j and random.random() < 0.1:\n",
        "                graph[i][j] = random.randint(1, 10)\n",
        "\n",
        "    with open(\"graph.txt\", \"w\") as f:\n",
        "        f.write(str(n) + \"\\n\")\n",
        "        for row in graph:\n",
        "            f.write(\" \".join(map(str, row)) + \"\\n\")\n",
        "\n",
        "generate_graph()\n",
        "print(\"✅ Graph generated successfully\")"
