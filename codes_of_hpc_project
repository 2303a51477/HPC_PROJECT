        "            fscanf(f,\"%d\",&graph[i][j]);\n",
        "\n",
        "    fclose(f);\n",
        "\n",
        "    double s = omp_get_wtime();\n",
        "\n",
        "    for(int i=0;i<REPEAT;i++)\n",
